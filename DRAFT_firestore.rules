rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      // Identity check against team collection for priority role
      return isSignedIn() && (
        get(/databases/$(database)/documents/team/$(request.auth.uid)).data.role == 'Admin' ||
        request.auth.token.email == 'phidephefem@gmail.com'
      );
    }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'contactEmail', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.contactEmail is string && data.contactEmail.size() <= 256 &&
             data.status in ['active', 'onboarding', 'churned'];
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.id == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email == request.auth.token.email &&
             data.role in ['Admin', 'Strategist', 'Creative', 'Technical', 'Account Manager'];
    }

    function isValidDispatch(data) {
      return data.keys().hasAll(['id', 'to', 'subject', 'status', 'timestamp']) &&
             data.id is string &&
             data.to is string &&
             data.subject is string &&
             data.status in ['sent', 'failed', 'processing', 'delivered', 'bounced', 'cancelled', 'scheduled'];
    }

    // --- Collection Rules ---

    // Team Members
    match /team/{memberId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && isValidTeamMember(incoming()) && isValidId(memberId);
      allow update: if isSignedIn() && isEmailVerified() && (
        // Admin can update anything
        (isAdmin() && isValidTeamMember(incoming())) ||
        // User can update their own profile but NOT their role
        (isOwner(memberId) && isValidTeamMember(incoming()) && incoming().role == existing().role)
      );
      allow delete: if isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || resource.data.status == 'active'); 
      allow create: if isAdmin() && isValidClient(incoming()) && isValidId(clientId);
      allow update: if (isAdmin() || (isSignedIn() && isEmailVerified())) && isValidClient(incoming()) && (
        isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'lastActivity']))
      );
      allow delete: if isAdmin();
    }

    // Dispatches (Audit Trail)
    match /dispatches/{dispatchId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow create: if (isAdmin() || isSignedIn()) && isValidDispatch(incoming()) && isValidId(dispatchId);
      // Dispatches are essentially immutable audit logs
      allow update: if isAdmin() && isValidDispatch(incoming());
      allow delete: if false; // Audit logs should never be deleted
    }
  }
}
