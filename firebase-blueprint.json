{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Represents a marketing agency client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "contractValue": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "onboarding", "churned"] },
        "onboardingProgress": { "type": "number" },
        "lastActivity": { "type": "string" },
        "contractURL": { "type": "string" }
      },
      "required": ["id", "name", "contactEmail", "status"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "A staff member of the agency.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Strategist", "Creative", "Technical", "Account Manager"] },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] },
        "avatar": { "type": "string" },
        "lastActive": { "type": "string" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "EmailDispatchLog": {
      "title": "Email Dispatch Log",
      "description": "Record of a sent secure email.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "failed", "processing", "delivered", "bounced", "cancelled", "scheduled"] },
        "security_level": { "type": "string" },
        "timestamp": { "type": "string" },
        "open_count": { "type": "number" },
        "click_count": { "type": "number" }
      },
      "required": ["id", "to", "subject", "status", "timestamp"]
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients managed by the agency."
    },
    "/team/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of agency staff members."
    },
    "/dispatches/{dispatchId}": {
      "schema": "EmailDispatchLog",
      "description": "Audit trail of all email dispatches."
    }
  }
}
